# -------------------------------------------------------------
# ListItUp Environment Variables
# -------------------------------------------------------------
# NEVER commit the .env file to Git!
# -------------------------------------------------------------

# --- Google OAuth2 ---
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Click "Create Credentials" → "OAuth client ID"
# 3. Application type: "Web application"
# 4. Add Authorized redirect URI: https://listitup.duckdns.org/login/oauth2/code/google
# 5. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# --- GitHub OAuth2 ---
# Get these from: https://github.com/settings/developers
# 1. Go to GitHub Settings → Developer settings → OAuth Apps
# 2. Click "New OAuth App"
# 3. Authorization callback URL: https://listitup.duckdns.org/login/oauth2/code/github
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# --- Email Notifications (SMTP) ---
# For Google Mail, you may need an App Password if 2FA is enabled
# App passwords: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-smtp-password-here
